# Copy this to .env and fill in your values
# Get your free Gemini API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# SQLite (default — no changes needed for local dev)
DATABASE_URL=sqlite:///./sales_agent.db

# For Railway Postgres (optional)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Gemini model (free tier works great)
GEMINI_MODEL=gemini-1.5-flash

# Confidence threshold below which responses are auto-flagged
FLAG_THRESHOLD=0.65
